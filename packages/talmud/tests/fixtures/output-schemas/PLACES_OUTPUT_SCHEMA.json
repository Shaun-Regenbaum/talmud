{
  "name": "places_marks",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["instances"],
    "properties": {
      "instances": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["excerpt", "fields"],
          "properties": {
            "excerpt": {
              "type": "string"
            },
            "fields": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "nameHe", "kind", "region", "knownAs"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "nameHe": {
                  "type": "string"
                },
                "kind": {
                  "type": "string",
                  "enum": ["city", "academy", "land", "region"]
                },
                "region": {
                  "type": "string",
                  "enum": ["israel", "bavel", "other"]
                },
                "knownAs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
