{
  "name": "rabbi_geography",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["birthplace", "primaryStudyPlaces", "notablePlaces", "movements", "prose"],
    "properties": {
      "birthplace": {
        "type": "object",
        "additionalProperties": false,
        "required": ["place", "region", "seq"],
        "properties": {
          "place": {
            "type": "string"
          },
          "region": {
            "type": "string",
            "enum": ["israel", "bavel", "other", "unknown"]
          },
          "seq": {
            "type": "integer"
          }
        }
      },
      "primaryStudyPlaces": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["place", "academy", "period", "seq"],
          "properties": {
            "place": {
              "type": "string"
            },
            "academy": {
              "type": "string"
            },
            "period": {
              "type": "string"
            },
            "seq": {
              "type": "integer"
            }
          }
        }
      },
      "notablePlaces": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["place", "event", "seq"],
          "properties": {
            "place": {
              "type": "string"
            },
            "event": {
              "type": "string"
            },
            "seq": {
              "type": "integer"
            }
          }
        }
      },
      "movements": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to", "approximateWhen", "reason", "seq"],
          "properties": {
            "from": {
              "type": "string"
            },
            "to": {
              "type": "string"
            },
            "approximateWhen": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            },
            "seq": {
              "type": "integer"
            }
          }
        }
      },
      "prose": {
        "type": "string"
      }
    }
  }
}
