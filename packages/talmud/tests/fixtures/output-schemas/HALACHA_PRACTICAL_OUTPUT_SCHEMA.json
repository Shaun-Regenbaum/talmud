{
  "name": "halacha_practical",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["shape", "best", "fallback", "statement", "rows", "note"],
    "properties": {
      "shape": {
        "type": "string",
        "enum": ["best-fallback", "statement", "taxonomy"]
      },
      "best": {
        "type": "string"
      },
      "fallback": {
        "type": "string"
      },
      "statement": {
        "type": "string"
      },
      "rows": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["when", "value"],
          "properties": {
            "when": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          }
        }
      },
      "note": {
        "type": "string"
      }
    }
  }
}
